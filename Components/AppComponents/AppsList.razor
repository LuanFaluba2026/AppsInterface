@using AppsInterface.Components.Models.Enum
@rendermode InteractiveServer
@inject NavigationManager nav

<div class="card py-4">
    <div class="card shadow-sm border-0 rounded-4 p-4">

        <div class="d-flex flex-wrap gap-3 align-items-center mb-4">
            <div class="flex-grow-1">
                <input type="text"
                       @bind="searchTerm"
                       @bind:event="oninput"
                       class="form-control"
                       placeholder="Pesquisar apps..." />
            </div>

            <div style="min-width: 220px;">
                <select @bind="selectedFilterType" class="form-select">
                    <option value="">Todos os tipos</option>
                    @foreach (var type in Enum.GetValues<AppType>())
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
        </div>

        @if (apps.Count == 0)
        {
            <div class="text-center text-muted py-5">
                <h5>Nenhum app encontrado</h5>
            </div>
        }
        else
        {
            <div class="d-flex flex-nowrap gap-4 overflow-auto pb-2">
                @foreach (var app in apps)
                {
                    <div style="flex: 0 0 280px; width: 280px; cursor: pointer;" @onclick='() => nav.NavigateTo($"/apps/{app.Id}")'>
                        <div class="card h-100 shadow-sm border-2 rounded-4">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title fw-bold text-truncate">
                                    @app.Name
                                </h5>

                                <span class="badge bg-primary mb-3 align-self-start">
                                    @app.Type
                                </span>

                                <p class="card-text text-muted app-description" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                    @app.Description
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>
@code {
    List<PublishedApp> apps = AppsController.GetAvailableApps();

    private string? _searchTerm;
    string? searchTerm
    {
        get => _searchTerm;
        set
        {
            _searchTerm = value;
            SearchApps();
        }
    }
    private AppType? _selectedFilterType;
    AppType? selectedFilterType
    {
        get => _selectedFilterType;
        set
        {
            _selectedFilterType = value;
            searchAppsByType();
        }
    }
    void SearchApps()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            apps = AppsController.GetAvailableApps();
        else
            apps = AppsController.GetAvailableApps()
                .Where(app =>
                    app.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    app.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
                .ToList();
    }
    void searchAppsByType()
    {
        if (selectedFilterType == null)
            apps = AppsController.GetAvailableApps();
        else
            apps = AppsController.GetAvailableApps()
                .Where(app => app.Type == selectedFilterType)
                .ToList();
    }
}
